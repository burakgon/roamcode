# Generate a fresh capability into this ignored local file. Never commit its contents.
ROAMCODE_RELAY_ROOT_TOKEN_FILE=./secrets/relay-root-token

# Static PWA origin and the exact browser Origin allowed to open relay sockets.
ROAMCODE_APP_DOMAIN=app.example.com
ROAMCODE_RELAY_ALLOWED_ORIGINS=https://app.example.com
ROAMCODE_RELAY_ACCOUNTS_ENABLED=1

# DNS name whose A/AAAA record points to this relay host.
ROAMCODE_RELAY_DOMAIN=relay.example.com

# Optional immutable registry reference. The local image is built when omitted.
ROAMCODE_RELAY_IMAGE=roamcode-relay:local
ROAMCODE_EDGE_IMAGE=roamcode-edge:local
