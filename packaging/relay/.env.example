# Install a mode-0400, uid/gid-10001 container copy here. Never commit its contents.
ROAMCODE_RELAY_ROOT_TOKEN_FILE=./secrets/relay-root-token.container
ROAMCODE_RELAY_PREVIOUS_ROOT_TOKEN_SOURCE=./secrets/previous-root-tokens

# One canonical origin serves the account shell, terminal PWA, control API, and
# bounded relay routes. Its A/AAAA record points at this VM.
ROAMCODE_DOMAIN=roamcode.example.com
ROAMCODE_RELAY_ALLOWED_ORIGINS=https://roamcode.example.com
ROAMCODE_RELAY_ACCOUNTS_ENABLED=1

# Internal Compose service addresses. Override only when the API or relay is on
# another private Docker network; never point either value at the public edge.
ROAMCODE_API_UPSTREAM=api:4400
ROAMCODE_RELAY_UPSTREAM=relay:4281

# Optional immutable registry reference. The local image is built when omitted.
ROAMCODE_RELAY_IMAGE=roamcode-relay:local
ROAMCODE_EDGE_IMAGE=roamcode-edge:local
