# Public hostnames. Do not put credentials in this file.
ROAMCODE_APP_DOMAIN=app.roamcode.ai
ROAMCODE_RELAY_DOMAIN=relay.roamcode.ai

# Exact release image digests from roamcode-cloud-images.json.
ROAMCODE_RELAY_IMAGE=ghcr.io/OWNER/REPOSITORY-relay@sha256:REPLACE_WITH_RELEASE_MANIFEST_DIGEST
ROAMCODE_EDGE_IMAGE=ghcr.io/OWNER/REPOSITORY-edge@sha256:REPLACE_WITH_RELEASE_MANIFEST_DIGEST
CLOUDFLARED_IMAGE=cloudflare/cloudflared@sha256:404528c1cd63c3eb882c257ae524919e4376115e6fe57befca8d603656a91a4c

# Secret Manager resource names, never secret values.
ROAMCODE_RELAY_ROOT_SECRET=roamcode-cloud-relay-root
ROAMCODE_TUNNEL_TOKEN_SECRET=roamcode-cloudflare-tunnel-token
