{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "roamcode-site",
  "compatibility_date": "2026-07-01",
  "main": "worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "routes": [{ "pattern": "roamcode.ai", "custom_domain": true }],
  "observability": { "enabled": true },
}
