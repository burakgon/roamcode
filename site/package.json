{
  "name": "roamcode-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "pnpm": {
    "allowBuilds": {
      "esbuild": true,
      "workerd": true
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@xterm/xterm": "^6.0.0",
    "lenis": "^1.3.25"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "wrangler": "^4.107.1"
  }
}
